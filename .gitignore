
# Environment / secrets
.env.local
.env
*.env

# Per-agent path configuration (points to external world/ and meta/ directories)
*/local-paths.conf

# Temporary / scratch files
tmp_*
*.tmp

# OS files
.DS_Store
Thumbs.db
desktop.ini
*.stackdump

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Python artifacts
__pycache__/
*.pyc
*.pyo
.venv/
venv/
# Python interpreter shim (auto-created by _paths.sh on Windows)
core/scripts/.python-shim/

# Node artifacts
node_modules/

# File history (auto-generated by write scripts)
*/.history/

# File locks (transient)
*.lock

# Ephemeral session state (recreated each session per agent)
# Pattern */session/ matches any agent's session dir at the project root
*/session/
# Agent binding files (managed by /start)
.active-agent
.active-agent-*
# Session ID (written by SessionStart hook, read by _paths.sh for Tier 2 resolution)
.latest-session-id
# Hook coordination files (one-shot breadcrumbs, consumed after reading)
.stop-hook-stdin.json
# Stop hook audit log (persistent, diagnoses why sessions die)
.stop-hook-log
# Crash recovery markers (written by StopFailure hook, consumed by /boot)
*/session/crash-marker

# Safety net: world/ and meta/ should never exist at repo root
# (they live at external paths configured in local-paths.conf)
/world/
/meta/
