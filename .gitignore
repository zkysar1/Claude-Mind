
# Environment / secrets
.env.local
.env
*.env

# Temporary / scratch files
tmp_*
*.tmp

# OS files
.DS_Store
Thumbs.db
desktop.ini
*.stackdump

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Python artifacts
__pycache__/
*.pyc
*.pyo
core/scripts/.python-shim/
core/scripts/.capture-insights.log
.venv/
venv/

# Node artifacts
node_modules/

# External state directories (world/ and meta/ live at external paths via <agent>/local-paths.conf)
# If they happen to exist locally during development, ignore them:
world/
meta/

# Agent directories (generated by /start, recreated from core/config/ initial_state: sections)
# Each agent is a top-level directory (e.g., alpha/). Ignored to keep repo domain-free.
# The init-agent.sh reserved names (core, meta, world, node_modules, .git, .claude, .github)
# cannot be agent names.

# Per-agent local path config (contains machine-specific external paths)
**/local-paths.conf

# Forged skills (domain-specific, registered in <agent>/forged-skills.yaml)
# Base skills are committed; forged skills are agent-created and domain-specific.
# Add your forged skill directories here per deployment, e.g.:
# .claude/skills/my-forged-skill/

# User-specific settings (framework settings live in .claude/settings.json)
.claude/settings.local.json

.claude/worktrees
